DJANGO_SECRET_KEY=your-secret-key-here
# ⚠️  DEVELOPER SETUP: override the two lines below in your local .env
#     DJANGO_DEBUG=True
#     DJANGO_SETTINGS_MODULE=store.settings.dev
# Defaults are intentionally set to production-safe values so a misconfigured
# deploy fails closed rather than exposing debug output.
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=store.settings.prod
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (prod only)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_SECRET_HASH=your-webhook-hash

# Email (dev: console, prod: smtp)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=hello@yourdomain.co.ke
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Mutisya <hello@yourdomain.co.ke>
